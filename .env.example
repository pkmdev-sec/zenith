# Optional runtime defaults for Zenith.
# Provider credentials are read by pi-coding-agent in the usual ways.

# ── Zenith runtime knobs ───────────────────────────────────
# Override the Zenith home directory (default: ~/.zenith). Used for
# agent dir, sessions, memory, and swarm-work.
ZENITH_HOME=
# Default model spec (e.g., anthropic/claude-opus-4-6). Can be overridden
# per-invocation with `--model`.
ZENITH_MODEL=
# Default thinking level: off|minimal|low|medium|high|xhigh.
ZENITH_THINKING=medium
# Cap on agents per research request. Overrides settings.swarm.maxAgentsPerRequest.
# Used by log_agent_spawn to enforce budget.
ZENITH_MAX_AGENTS=
# Skip the Pandoc auto-install step during `zenith setup` (macOS/Linux).
ZENITH_SKIP_PANDOC_INSTALL=
# Force a specific package manager for runtime workspace: npm|pnpm|bun.
ZENITH_PACKAGE_MANAGER=
# Override the Node.js version baked into native bundles. Must be >= engines.node.
ZENITH_BUNDLED_NODE_VERSION=

# ── Model provider credentials ─────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
CEREBRAS_API_KEY=
HF_TOKEN=
OPENCODE_API_KEY=
AI_GATEWAY_API_KEY=
AZURE_OPENAI_API_KEY=

# ── Optional: higher Semantic Scholar rate limits ──────────
SEMANTIC_SCHOLAR_API_KEY=
